# API Settings
API_TITLE=Nova Agent API
API_VERSION=0.1.0
API_DESCRIPTION=A powerful agent-based API service

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Groq Settings
LITE_LLM_API_KEY=
LITE_LLM_MODEL=openrouter/minimax/minimax-m2.5:nitro
BRAVE_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LITELLM_LOG=ERROR
# Pydantic AI Validation Settings
PYDANTIC_AI_MAX_RETRIES=3
PYDANTIC_AI_VALIDATION_DEBUG=false
PYDANTIC_AI_ASYNC_ONLY=true
